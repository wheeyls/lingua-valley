{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/organizations/:path*", "destination": "/index.html" },
    { "source": "/leaderboard", "destination": "/index.html" },
    { "source": "/reset-password", "destination": "/index.html" }
  ]
}
